# MapaCultural - Production Environment Configuration
# Copy this file to .env and configure with your actual values
# Usage: docker compose -f compose.prod.yaml up -d

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL database password
# IMPORTANT: Use a strong password in production
DB_PASSWORD=changeme

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# Base URL of your application (include protocol, no trailing slash)
BASE_URL=http://localhost

# Application environment (should be 'production' in production)
APP_ENV=production

# Debug mode (should be 'false' in production)
APP_DEBUG=false

# =============================================================================
# MAILER CONFIGURATION
# =============================================================================
# SMTP server configuration
# Format: smtp://[user:password@]host:port
# Examples:
#   - smtp://localhost:25 (local mail server, no auth)
#   - smtp://user:password@smtp.gmail.com:587 (Gmail)
#   - smtp://user:password@smtp.sendgrid.net:587 (SendGrid)
MAILER_TRANSPORT=smtp://localhost:25

# From email address for outgoing emails
MAILER_FROM=noreply@mapas.example.com

# =============================================================================
# RECAPTCHA CONFIGURATION
# =============================================================================
# Google reCAPTCHA v2 keys
# Get your keys at: https://www.google.com/recaptcha/admin
RECAPTCHA_SITEKEY=
RECAPTCHA_SECRET=

# =============================================================================
# PERFORMANCE CONFIGURATION
# =============================================================================
# Number of PHP-FPM worker processes
# Recommended: 2-4 per CPU core
NUM_PROCESSES=4

# Number of processes for MapaCultural updates
MC_UPDATES_PROCESSES=2

# Pending cache recreation interval (in minutes)
PCACHE_INTERVAL=30

# Background jobs interval (in minutes)
JOBS_INTERVAL=15

# =============================================================================
# SUBSITES CONFIGURATION
# =============================================================================
# Disable subsites feature (set to 'true' to disable)
DISABLE_SUBSITES=false

# =============================================================================
# ASSET CONFIGURATION
# =============================================================================
# Redirect 404 assets to another URL (optional)
# Example: https://cdn.example.com
REDIRECT_404_ASSETS=
