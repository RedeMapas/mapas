---
interface BreadcrumbItem {
    label: string;
    href?: string;
}

interface Props {
    items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<div class="breadcrumbs text-sm mb-6">
    <ul>
        {items.map((item) => (
            item.href
                ? <li><a href={item.href} class="text-primary hover:underline">{item.label}</a></li>
                : <li class="font-semibold">{item.label}</li>
        ))}
    </ul>
</div>
