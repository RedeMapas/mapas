---
import '../styles/global.css';

interface Props {
    title?: string;
}

const { title = 'MapaCultural' } = Astro.props;
const phpUrl = import.meta.env.PHP_API_URL;
---

<!DOCTYPE html>
<html lang="pt-BR" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href={`${phpUrl}/favicon.ico`} />
    <title>{title}</title>
</head>
<body class="min-h-screen bg-base-200">
    <div class="navbar bg-primary text-primary-content px-6">
        <div class="navbar-start">
            <h1 class="text-lg font-semibold">MapaCultural</h1>
        </div>
        <div class="navbar-end">
            <a href={phpUrl || '/'} class="btn btn-ghost btn-sm text-primary-content/80 hover:text-primary-content">Voltar ao portal</a>
        </div>
    </div>
    <main class="max-w-4xl mx-auto p-6">
        <slot />
    </main>
</body>
</html>
