---
import HomeLayout from '../../../layouts/HomeLayout.astro';

const { id } = Astro.params;
---

<HomeLayout title="Editar agente — Rede Mapas">
    <div class="edit-page">
        <div class="page-container">

            <nav class="breadcrumb" aria-label="Navegação">
                <a href="/">Início</a>
                <span aria-hidden="true">›</span>
                <a href="/entidades">Entidades</a>
                <span aria-hidden="true">›</span>
                <span id="breadcrumb-name">Editar agente</span>
            </nav>

            <!-- Estado de carregamento -->
            <div id="state-loading" class="edit-state">
                <div class="edit-spinner" aria-label="Carregando…"></div>
                <p>Carregando dados do agente…</p>
            </div>

            <!-- Estado: não autenticado -->
            <div id="state-forbidden" class="edit-state" hidden>
                <p class="edit-state__icon" aria-hidden="true">🔒</p>
                <h1>Acesso restrito</h1>
                <p>Você precisa estar autenticado para editar este agente.</p>
                <div class="edit-state__actions">
                    <a id="login-link" class="edit-back-btn edit-back-btn--primary" href="/auth/login">Fazer login</a>
                </div>
            </div>

            <!-- Estado: não encontrado -->
            <div id="state-notfound" class="edit-state" hidden>
                <p class="edit-state__icon" aria-hidden="true">🔍</p>
                <h1>Agente não encontrado</h1>
                <p>O agente com ID <strong>{id}</strong> não existe, foi removido, ou você não tem permissão para editá-lo.</p>
                <div class="edit-state__actions">
                    <a class="edit-back-btn" href="/entidades">← Voltar</a>
                </div>
            </div>

            <!-- Estado: erro genérico -->
            <div id="state-error" class="edit-state" hidden>
                <p class="edit-state__icon" aria-hidden="true">⚠️</p>
                <h1>Erro ao carregar</h1>
                <p id="state-error-msg">Não foi possível conectar ao servidor.</p>
                <div class="edit-state__actions">
                    <button class="edit-back-btn edit-back-btn--primary" onclick="window.location.reload()">Tentar novamente</button>
                    <a class="edit-back-btn" href="/entidades">← Voltar</a>
                </div>
            </div>

            <!-- Formulário (oculto até carregar) -->
            <div id="edit-layout" class="edit-layout" hidden>
                <header class="edit-header">
                    <div class="edit-header__label">Agente</div>
                    <h1 id="header-title" class="edit-header__title"></h1>
                    <span id="header-type" class="edit-header__type"></span>
                </header>

                <div class="edit-body">
                    <div class="edit-main">
                        <div class="edit-card">
                            <h2 class="edit-card__title">Informações básicas</h2>

                            <div id="alert-success" class="edit-alert edit-alert--success" role="alert" hidden>
                                Alterações salvas com sucesso.
                            </div>
                            <div id="alert-error" class="edit-alert edit-alert--error" role="alert" hidden></div>

                            <form id="edit-form" class="edit-form" novalidate>
                                <div class="edit-form__field">
                                    <label class="edit-form__label" for="field-name">
                                        Nome <span aria-hidden="true" class="edit-form__required">*</span>
                                    </label>
                                    <input
                                        id="field-name"
                                        name="name"
                                        class="edit-form__input"
                                        type="text"
                                        required
                                        maxlength="255"
                                        autocomplete="off"
                                    />
                                    <span id="error-name" class="edit-form__error-msg" role="alert" hidden></span>
                                </div>

                                <div class="edit-form__field">
                                    <label class="edit-form__label" for="field-short">
                                        Descrição curta
                                        <span class="edit-form__hint">Aparece nos cards e buscas (máx. 400 caracteres)</span>
                                    </label>
                                    <textarea
                                        id="field-short"
                                        name="shortDescription"
                                        class="edit-form__textarea edit-form__textarea--short"
                                        maxlength="400"
                                        rows="3"
                                    ></textarea>
                                    <span id="char-count" class="edit-form__char-count">0/400</span>
                                </div>

                                <div class="edit-form__field">
                                    <label class="edit-form__label" for="field-long">
                                        Descrição completa
                                        <span class="edit-form__hint">Apresentada na página de detalhes</span>
                                    </label>
                                    <textarea
                                        id="field-long"
                                        name="longDescription"
                                        class="edit-form__textarea edit-form__textarea--long"
                                        rows="10"
                                    ></textarea>
                                </div>

                                <div class="edit-form__actions">
                                    <button id="submit-btn" type="submit" class="edit-form__btn edit-form__btn--primary">
                                        Salvar alterações
                                    </button>
                                    <a id="cancel-link" class="edit-form__btn edit-form__btn--secondary" href="#">
                                        Cancelar
                                    </a>
                                </div>
                            </form>
                        </div>
                    </div>

                    <aside class="edit-sidebar">
                        <div class="edit-info-card">
                            <h2 class="edit-info-card__title">Sobre este agente</h2>
                            <dl class="edit-info-list">
                                <dt>ID</dt>
                                <dd>#{id}</dd>
                                <dt id="type-label" hidden>Tipo</dt>
                                <dd id="type-value"></dd>
                            </dl>
                            <a id="portal-link" class="edit-portal-link" href={`/agente/${id}/info`} target="_blank" rel="noopener">
                                Ver página pública ↗
                            </a>
                        </div>
                    </aside>
                </div>
            </div>

        </div>
    </div>

    <script define:vars={{ agentId: id }}>
        const $ = id => document.getElementById(id);

        function showState(name) {
            for (const s of ['loading', 'forbidden', 'notfound', 'error']) {
                $(`state-${s}`).hidden = s !== name;
            }
            $('edit-layout').hidden = name !== null;
        }

        async function loadAgent() {
            showState('loading');
            try {
                const res = await fetch(`/agente/${agentId}/single?@select=id,name,shortDescription,longDescription,type,status`, {
                    credentials: 'same-origin',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                });

                if (res.status === 401 || res.status === 403) {
                    $('login-link').href = `/auth/login?next=/agente/${agentId}/editar`;
                    showState('forbidden');
                    return;
                }

                if (res.status === 404) {
                    showState('notfound');
                    return;
                }

                if (!res.ok) {
                    $('state-error-msg').textContent = `Erro ao carregar o agente (HTTP ${res.status}).`;
                    showState('error');
                    return;
                }

                const agent = await res.json();
                if (agent?.error) {
                    showState('notfound');
                    return;
                }
                if (!agent?.currentUserPermissions?.modify) {
                    $('login-link').href = `/auth/login?next=/agente/${agentId}/editar`;
                    showState('forbidden');
                    return;
                }
                populateForm(agent);
                showState(null); // mostra o formulário
            } catch (err) {
                $('state-error-msg').textContent = 'Não foi possível conectar ao servidor.';
                showState('error');
            }
        }

        function populateForm(agent) {
            $('breadcrumb-name').textContent = agent.name ?? 'Editar agente';
            $('header-title').textContent = agent.name ?? '';

            if (agent.type?.name) {
                $('header-type').textContent = agent.type.name;
                $('type-label').hidden = false;
                $('type-value').textContent = agent.type.name;
            }

            $('cancel-link').href = `/agente/${agentId}/info`;

            const fieldName = $('field-name');
            const fieldShort = $('field-short');
            const fieldLong = $('field-long');
            const charCount = $('char-count');

            fieldName.value = agent.name ?? '';
            fieldShort.value = agent.shortDescription ?? '';
            fieldLong.value = agent.longDescription ?? '';
            charCount.textContent = `${fieldShort.value.length}/400`;

            fieldShort.addEventListener('input', () => {
                charCount.textContent = `${fieldShort.value.length}/400`;
            });

            $('edit-form').addEventListener('submit', async (e) => {
                e.preventDefault();
                await saveAgent();
            });
        }

        async function saveAgent() {
            $('alert-success').hidden = true;
            $('alert-error').hidden = true;
            $('error-name').hidden = true;
            $('field-name').classList.remove('edit-form__input--error');

            const name = $('field-name').value.trim();
            if (!name) {
                $('error-name').textContent = 'O nome é obrigatório.';
                $('error-name').hidden = false;
                $('field-name').classList.add('edit-form__input--error');
                $('field-name').focus();
                return;
            }

            const btn = $('submit-btn');
            btn.disabled = true;
            btn.textContent = 'Salvando…';

            try {
                const res = await fetch(`/agente/${agentId}/single`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest',
                    },
                    credentials: 'same-origin',
                    body: JSON.stringify({
                        name,
                        shortDescription: $('field-short').value.trim(),
                        longDescription: $('field-long').value.trim(),
                    }),
                });

                if (res.status === 401 || res.status === 403) {
                    $('alert-error').textContent = 'Sem permissão. Faça login e tente novamente.';
                    $('alert-error').hidden = false;
                    return;
                }

                if (!res.ok) {
                    let msg = `Erro ao salvar (HTTP ${res.status}).`;
                    try {
                        const json = await res.json();
                        if (json?.error) msg = json.error;
                        else if (json?.message) msg = json.message;
                    } catch (parseErr) {
                        console.error('[edit] Failed to parse error response:', parseErr);
                    }
                    $('alert-error').textContent = msg;
                    $('alert-error').hidden = false;
                    return;
                }

                $('alert-success').hidden = false;
                window.scrollTo({ top: 0, behavior: 'smooth' });
            } catch {
                $('alert-error').textContent = 'Não foi possível conectar ao servidor.';
                $('alert-error').hidden = false;
            } finally {
                btn.disabled = false;
                btn.textContent = 'Salvar alterações';
            }
        }

        loadAgent();
    </script>

    <style>
        .edit-page {
            min-height: 100vh;
            padding: 2rem 0 4rem;
        }

        .container {
            width: min(1180px, 92vw);
            margin: 0 auto;
        }

        /* ── BREADCRUMB ──────────────────────────────── */
        .breadcrumb {
            display: flex;
            align-items: center;
            gap: 0.4rem;
            font-size: 0.82rem;
            color: #666;
            margin-bottom: 1.5rem;
            flex-wrap: wrap;
        }

        .breadcrumb a { color: #0056c8; text-decoration: none; }
        .breadcrumb a:hover { text-decoration: underline; }
        .breadcrumb span:last-child { color: #1f1f1f; font-weight: 600; }

        /* ── STATES ──────────────────────────────────── */
        .edit-state {
            background: #fff;
            border-radius: 10px;
            border: 1px solid #e8e8e8;
            padding: 3rem 2rem;
            text-align: center;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.75rem;
        }

        .edit-spinner {
            width: 36px;
            height: 36px;
            border: 3px solid #e0e0e0;
            border-top-color: #0056c8;
            border-radius: 50%;
            animation: spin 0.7s linear infinite;
        }

        @keyframes spin { to { transform: rotate(360deg); } }

        .edit-state__icon { font-size: 3rem; margin: 0; }
        .edit-state h1 { font-size: 1.4rem; color: #1f1f1f; margin: 0; }
        .edit-state p { color: #666; margin: 0; max-width: 420px; }
        .edit-state__actions { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; margin-top: 0.5rem; }

        /* ── BUTTONS ─────────────────────────────────── */
        .edit-back-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: 2px solid #0056c8;
            border-radius: 999px;
            padding: 0.65rem 1.5rem;
            min-height: 44px;
            font-family: inherit;
            font-weight: 700;
            font-size: 0.875rem;
            text-decoration: none;
            background: #fff;
            color: #0056c8;
            cursor: pointer;
            transition: filter 0.15s;
        }

        .edit-back-btn--primary { background: #0056c8; color: #fff; }
        .edit-back-btn:hover { filter: brightness(1.07); }

        /* ── HEADER ──────────────────────────────────── */
        .edit-header {
            background: #fff;
            border: 1px solid #e8e8e8;
            border-radius: 10px;
            padding: 1.5rem 2rem;
            margin-bottom: 1.5rem;
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
        }

        .edit-header__label {
            font-size: 0.72rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: #0056c8;
        }

        .edit-header__title {
            margin: 0;
            font-size: clamp(1.2rem, 2.5vw, 1.8rem);
            font-weight: 700;
            color: #0033a0;
            line-height: 1.15;
        }

        .edit-header__type { font-size: 0.82rem; color: #666; font-weight: 600; }

        /* ── LAYOUT ──────────────────────────────────── */
        .edit-body {
            display: grid;
            grid-template-columns: 1fr 280px;
            gap: 1.5rem;
            align-items: start;
        }

        /* ── CARD ────────────────────────────────────── */
        .edit-card {
            background: #fff;
            border: 1px solid #e8e8e8;
            border-radius: 10px;
            padding: 1.75rem 2rem;
        }

        .edit-card__title {
            margin: 0 0 1.5rem;
            font-size: 0.78rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: #888;
            padding-bottom: 0.75rem;
            border-bottom: 1px solid #eee;
        }

        /* ── ALERTS ──────────────────────────────────── */
        .edit-alert {
            border-radius: 8px;
            padding: 0.875rem 1.125rem;
            font-size: 0.92rem;
            font-weight: 600;
            line-height: 1.4;
            margin-bottom: 1.25rem;
        }

        .edit-alert--success { background: #dcfce7; color: #166534; border: 1px solid #bbf7d0; }
        .edit-alert--error   { background: #fee2e2; color: #991b1b; border: 1px solid #fecaca; }

        /* ── FORM ────────────────────────────────────── */
        .edit-form { display: flex; flex-direction: column; gap: 1.5rem; }

        .edit-form__field { display: flex; flex-direction: column; gap: 0.4rem; }

        .edit-form__label {
            font-size: 0.875rem;
            font-weight: 700;
            color: #1f1f1f;
            display: flex;
            flex-direction: column;
            gap: 0.2rem;
        }

        .edit-form__required { color: #dc2626; }

        .edit-form__hint { font-size: 0.78rem; font-weight: 400; color: #666; }

        .edit-form__input,
        .edit-form__textarea {
            font-family: inherit;
            font-size: 0.95rem;
            color: #1f1f1f;
            background: #fff;
            border: 1.5px solid #d1d5db;
            border-radius: 6px;
            padding: 0.6rem 0.875rem;
            transition: border-color 0.15s, box-shadow 0.15s;
            width: 100%;
        }

        .edit-form__input:focus,
        .edit-form__textarea:focus {
            outline: none;
            border-color: #0056c8;
            box-shadow: 0 0 0 3px rgba(0, 86, 200, 0.12);
        }

        .edit-form__input--error { border-color: #dc2626; }
        .edit-form__input--error:focus {
            border-color: #dc2626;
            box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.12);
        }

        .edit-form__textarea { resize: vertical; line-height: 1.5; }
        .edit-form__textarea--short { min-height: 80px; }
        .edit-form__textarea--long  { min-height: 200px; }

        .edit-form__char-count { font-size: 0.75rem; color: #999; text-align: right; margin-top: -0.2rem; }
        .edit-form__error-msg  { font-size: 0.8rem; color: #dc2626; font-weight: 600; }

        .edit-form__actions {
            display: flex;
            gap: 0.75rem;
            flex-wrap: wrap;
            padding-top: 0.5rem;
            border-top: 1px solid #e8e8e8;
        }

        .edit-form__btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: none;
            border-radius: 999px;
            padding: 0.65rem 1.5rem;
            min-height: 44px;
            font-family: inherit;
            font-size: 0.875rem;
            font-weight: 700;
            cursor: pointer;
            text-decoration: none;
            transition: filter 0.15s, box-shadow 0.15s, opacity 0.15s;
        }

        .edit-form__btn:hover:not(:disabled) {
            filter: brightness(1.07);
            box-shadow: 0 2px 8px rgba(0,0,0,0.15);
        }

        .edit-form__btn:disabled { opacity: 0.6; cursor: not-allowed; }
        .edit-form__btn--primary  { background: #0056c8; color: #fff; }
        .edit-form__btn--secondary { background: #fff; color: #0056c8; border: 2px solid #0056c8; }

        /* ── SIDEBAR ─────────────────────────────────── */
        .edit-info-card {
            background: #fff;
            border: 1px solid #e8e8e8;
            border-radius: 10px;
            padding: 1.25rem 1.5rem;
            position: sticky;
            top: 72px;
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .edit-info-card__title {
            margin: 0;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: #888;
        }

        .edit-info-list { display: grid; grid-template-columns: 1fr; gap: 0.15rem; }

        .edit-info-list dt {
            font-size: 0.72rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: #999;
            margin-top: 0.65rem;
        }

        .edit-info-list dt:first-child { margin-top: 0; }
        .edit-info-list dd { margin: 0; font-size: 0.9rem; color: #1f1f1f; font-weight: 600; }

        .edit-portal-link { font-size: 0.82rem; font-weight: 700; color: #0056c8; text-decoration: none; }
        .edit-portal-link:hover { text-decoration: underline; }

        /* ── RESPONSIVE ──────────────────────────────── */
        @media (max-width: 860px) {
            .edit-body { grid-template-columns: 1fr; }
            .edit-sidebar { order: -1; }
            .edit-info-card { position: static; }
        }

        @media (max-width: 540px) {
            .edit-card { padding: 1.25rem; }
            .edit-header { padding: 1.25rem; }
        }
    </style>
</HomeLayout>
