---
import HomeLayout from '../../../layouts/HomeLayout.astro';

const { id } = Astro.params;
---

<HomeLayout title="Editar agente — Rede Mapas">
    <div class="bg-base-200 min-h-screen py-8">
        <div class="container mx-auto w-full max-w-[1180px] px-[4vw]">
            <div class="breadcrumbs text-sm mb-6">
                <ul>
                    <li><a href="/" class="text-primary hover:underline">Início</a></li>
                    <li><a href="/entidades" class="text-primary hover:underline">Entidades</a></li>
                    <li class="font-semibold" id="breadcrumb-name">Editar agente</li>
                </ul>
            </div>

            <div id="state-loading" class="hero min-h-[40vh]">
                <div class="hero-content flex-col gap-4 text-base-content/60">
                    <span class="loading loading-spinner loading-lg text-primary"></span>
                    <p>Carregando dados do agente…</p>
                </div>
            </div>

            <div id="state-forbidden" hidden>
                <div class="hero min-h-[40vh]">
                    <div class="hero-content">
                        <div class="text-center">
                            <p class="text-5xl mb-4" aria-hidden="true">🔒</p>
                            <h1 class="text-2xl font-bold">Acesso restrito</h1>
                            <p class="text-base-content/60 mt-2">Você precisa estar autenticado para editar este agente.</p>
                            <a id="login-link" class="btn btn-primary mt-6" href="/auth/login">Fazer login</a>
                        </div>
                    </div>
                </div>
            </div>

            <div id="state-notfound" hidden>
                <div class="hero min-h-[40vh]">
                    <div class="hero-content">
                        <div class="text-center">
                            <p class="text-5xl mb-4" aria-hidden="true">🔍</p>
                            <h1 class="text-2xl font-bold">Agente não encontrado</h1>
                            <p class="text-base-content/60 mt-2">O agente com ID <strong>{id}</strong> não existe, foi removido, ou você não tem permissão para editá-lo.</p>
                            <a class="btn btn-outline btn-primary mt-6" href="/entidades">← Voltar</a>
                        </div>
                    </div>
                </div>
            </div>

            <div id="state-error" hidden>
                <div class="hero min-h-[40vh]">
                    <div class="hero-content">
                        <div class="text-center">
                            <p class="text-5xl mb-4" aria-hidden="true">⚠️</p>
                            <h1 class="text-2xl font-bold">Erro ao carregar</h1>
                            <p class="text-base-content/60 mt-2" id="state-error-msg">Não foi possível conectar ao servidor.</p>
                            <div class="flex gap-3 justify-center mt-6">
                                <button class="btn btn-primary" onclick="window.location.reload()">Tentar novamente</button>
                                <a class="btn btn-outline btn-primary" href="/entidades">← Voltar</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div id="edit-layout" hidden>
                <div class="card bg-base-100 shadow-sm mb-6">
                    <div class="card-body">
                        <p class="text-xs font-bold uppercase tracking-wider text-primary">Agente</p>
                        <h1 id="header-title" class="text-xl md:text-2xl font-bold text-primary"></h1>
                        <span id="header-type" class="text-sm text-base-content/60 font-semibold"></span>
                    </div>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-6 items-start">
                    <div class="card bg-base-100 shadow-sm">
                        <div class="card-body">
                            <h2 class="text-xs font-bold uppercase tracking-wider text-base-content/50 border-b border-base-200 pb-3 mb-6">Informações básicas</h2>

                            <div id="alert-success" class="alert alert-success" role="alert" hidden>
                                Alterações salvas com sucesso.
                            </div>
                            <div id="alert-error" class="alert alert-error" role="alert" hidden></div>

                            <form id="edit-form" class="flex flex-col gap-6" novalidate>
                                <div class="form-control">
                                    <label class="label" for="field-name">
                                        <span class="label-text font-bold">Nome <span class="text-error">*</span></span>
                                    </label>
                                    <input id="field-name" name="name" type="text" required maxlength="255" autocomplete="off" class="input input-bordered w-full" />
                                    <span id="error-name" class="text-error text-sm font-semibold mt-1" role="alert" hidden></span>
                                </div>

                                <div class="form-control">
                                    <label class="label" for="field-short">
                                        <span class="label-text font-bold">Descrição curta</span>
                                        <span class="label-text-alt text-base-content/50">Aparece nos cards e buscas (máx. 400 caracteres)</span>
                                    </label>
                                    <textarea id="field-short" name="shortDescription" maxlength="400" rows="3" class="textarea textarea-bordered w-full"></textarea>
                                    <span id="char-count" class="text-right text-xs text-base-content/40 mt-1">0/400</span>
                                </div>

                                <div class="form-control">
                                    <label class="label" for="field-long">
                                        <span class="label-text font-bold">Descrição completa</span>
                                        <span class="label-text-alt text-base-content/50">Apresentada na página de detalhes</span>
                                    </label>
                                    <textarea id="field-long" name="longDescription" rows="10" class="textarea textarea-bordered w-full"></textarea>
                                </div>

                                <div class="flex gap-3 flex-wrap pt-4 border-t border-base-200">
                                    <button id="submit-btn" type="submit" class="btn btn-primary">Salvar alterações</button>
                                    <a id="cancel-link" class="btn btn-outline btn-primary" href="#">Cancelar</a>
                                </div>
                            </form>
                        </div>
                    </div>

                    <aside>
                        <div class="card bg-base-100 shadow-sm sticky top-20">
                            <div class="card-body gap-3">
                                <h2 class="text-xs font-bold uppercase tracking-wider text-base-content/50">Sobre este agente</h2>
                                <dl class="space-y-2">
                                    <dt class="text-xs font-bold uppercase tracking-wider text-base-content/40">ID</dt>
                                    <dd class="text-sm font-semibold">#{id}</dd>
                                    <dt id="type-label" class="text-xs font-bold uppercase tracking-wider text-base-content/40" hidden>Tipo</dt>
                                    <dd id="type-value" class="text-sm font-semibold"></dd>
                                </dl>
                                <a id="portal-link" class="btn btn-ghost btn-sm text-primary" href={`/agente/${id}/info`} target="_blank" rel="noopener">Ver página pública ↗</a>
                            </div>
                        </div>
                    </aside>
                </div>
            </div>
        </div>
    </div>

    <script define:vars={{ agentId: id }}>
        const $ = id => document.getElementById(id);

        function showState(name) {
            for (const s of ['loading', 'forbidden', 'notfound', 'error']) {
                $(`state-${s}`).hidden = s !== name;
            }
            $('edit-layout').hidden = name !== null;
        }

        async function loadAgent() {
            showState('loading');
            try {
                const res = await fetch(`/agente/${agentId}/single?@select=id,name,shortDescription,longDescription,type,status`, {
                    credentials: 'same-origin',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                });

                if (res.status === 401 || res.status === 403) {
                    $('login-link').href = `/auth/login?next=/agente/${agentId}/editar`;
                    showState('forbidden');
                    return;
                }

                if (res.status === 404) {
                    showState('notfound');
                    return;
                }

                if (!res.ok) {
                    $('state-error-msg').textContent = `Erro ao carregar o agente (HTTP ${res.status}).`;
                    showState('error');
                    return;
                }

                const agent = await res.json();
                if (agent?.error) {
                    showState('notfound');
                    return;
                }
                if (!agent?.currentUserPermissions?.modify) {
                    $('login-link').href = `/auth/login?next=/agente/${agentId}/editar`;
                    showState('forbidden');
                    return;
                }
                populateForm(agent);
                showState(null);
            } catch (err) {
                $('state-error-msg').textContent = 'Não foi possível conectar ao servidor.';
                showState('error');
            }
        }

        function populateForm(agent) {
            $('breadcrumb-name').textContent = agent.name ?? 'Editar agente';
            $('header-title').textContent = agent.name ?? '';

            if (agent.type?.name) {
                $('header-type').textContent = agent.type.name;
                $('type-label').hidden = false;
                $('type-value').textContent = agent.type.name;
            }

            $('cancel-link').href = `/agente/${agentId}/info`;

            const fieldName = $('field-name');
            const fieldShort = $('field-short');
            const fieldLong = $('field-long');
            const charCount = $('char-count');

            fieldName.value = agent.name ?? '';
            fieldShort.value = agent.shortDescription ?? '';
            fieldLong.value = agent.longDescription ?? '';
            charCount.textContent = `${fieldShort.value.length}/400`;

            fieldShort.addEventListener('input', () => {
                charCount.textContent = `${fieldShort.value.length}/400`;
            });

            $('edit-form').addEventListener('submit', async (e) => {
                e.preventDefault();
                await saveAgent();
            });
        }

        async function saveAgent() {
            $('alert-success').hidden = true;
            $('alert-error').hidden = true;
            $('error-name').hidden = true;
            $('field-name').classList.remove('input-error');

            const name = $('field-name').value.trim();
            if (!name) {
                $('error-name').textContent = 'O nome é obrigatório.';
                $('error-name').hidden = false;
                $('field-name').classList.add('input-error');
                $('field-name').focus();
                return;
            }

            const btn = $('submit-btn');
            btn.disabled = true;
            btn.textContent = 'Salvando…';

            try {
                const res = await fetch(`/agente/${agentId}/single`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest',
                    },
                    credentials: 'same-origin',
                    body: JSON.stringify({
                        name,
                        shortDescription: $('field-short').value.trim(),
                        longDescription: $('field-long').value.trim(),
                    }),
                });

                if (res.status === 401 || res.status === 403) {
                    $('alert-error').textContent = 'Sem permissão. Faça login e tente novamente.';
                    $('alert-error').hidden = false;
                    return;
                }

                if (!res.ok) {
                    let msg = `Erro ao salvar (HTTP ${res.status}).`;
                    try {
                        const json = await res.json();
                        if (json?.error) msg = json.error;
                        else if (json?.message) msg = json.message;
                    } catch (parseErr) {
                        console.error('[edit] Failed to parse error response:', parseErr);
                    }
                    $('alert-error').textContent = msg;
                    $('alert-error').hidden = false;
                    return;
                }

                $('alert-success').hidden = false;
                window.scrollTo({ top: 0, behavior: 'smooth' });
            } catch {
                $('alert-error').textContent = 'Não foi possível conectar ao servidor.';
                $('alert-error').hidden = false;
            } finally {
                btn.disabled = false;
                btn.textContent = 'Salvar alterações';
            }
        }

        loadAgent();
    </script>
</HomeLayout>
