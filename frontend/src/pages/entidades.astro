---
import HomeLayout from '../layouts/HomeLayout.astro';

const phpUrl = import.meta.env.PHP_API_URL || '';

const baseParams = {
    '@limit': '6',
    '@select': 'id,name,shortDescription,type',
};

async function fetchEntities(endpoint: string, extra: Record<string, string> = {}) {
    try {
        const params = new URLSearchParams({ ...baseParams, ...extra });
        const res = await fetch(`${phpUrl}/api/${endpoint}/find?${params}`);
        if (!res.ok) return { items: [], total: 0 };
        const [items, total] = await Promise.all([
            res.json(),
            fetch(`${phpUrl}/api/${endpoint}/find?status=EQ(1)&@count=1`).then(r => r.json()).catch(() => 0),
        ]);
        return { items: Array.isArray(items) ? items : [], total: Number(total) || 0 };
    } catch {
        return { items: [], total: 0 };
    }
}

const [agents, spaces, events, opportunities] = await Promise.all([
    fetchEntities('agent', { status: 'EQ(1)', '@select': 'id,name,shortDescription,type,terms' }),
    fetchEntities('space', { status: 'EQ(1)', '@select': 'id,name,shortDescription,type' }),
    fetchEntities('event',  { status: 'EQ(1)', '@select': 'id,name,shortDescription,startsOn' }),
    fetchEntities('opportunity', { status: 'EQ(1)', '@select': 'id,name,shortDescription,registrationTo' }),
]);

function formatDate(dateStr: string | null): string {
    if (!dateStr) return '';
    return new Date(dateStr).toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' });
}

const sections = [
    {
        key: 'agents',
        label: 'Agentes',
        icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`,
        color: '#0056c8',
        bg: '#f0f4ff',
        data: agents,
        href: '/agente',
        meta: (item: any) => item.type?.name || '',
    },
    {
        key: 'spaces',
        label: 'Espaços',
        icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
        color: '#00a76f',
        bg: '#f0fdf8',
        data: spaces,
        href: '/espaco',
        meta: (item: any) => item.type?.name || '',
    },
    {
        key: 'events',
        label: 'Eventos',
        icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`,
        color: '#b45309',
        bg: '#fffbeb',
        data: events,
        href: '/evento',
        meta: (item: any) => item.startsOn ? formatDate(item.startsOn) : '',
    },
    {
        key: 'opportunities',
        label: 'Editais',
        icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`,
        color: '#7c3aed',
        bg: '#f5f3ff',
        data: opportunities,
        href: '/oportunidade',
        meta: (item: any) => item.registrationTo ? `Até ${formatDate(item.registrationTo)}` : '',
    },
];
---

<HomeLayout title="Entidades — Rede Mapas">
    <div class="entities-page">

        <div class="entities-header">
            <div class="container">
                <a class="entities-back" href="/">← Início</a>
                <h1>Explorar entidades</h1>
                <p class="entities-subtitle">Agentes, espaços, eventos e editais cadastrados na plataforma.</p>
            </div>
        </div>

        <!-- Resumo de contagens -->
        <div class="entities-stats">
            <div class="container">
                <div class="stats-grid">
                    {sections.map(s => (
                        <div class="stat-card" style={`--accent: ${s.color}; --bg: ${s.bg}`}>
                            <span class="stat-icon" set:html={s.icon} />
                            <div class="stat-info">
                                <span class="stat-count">{s.data.total > 0 ? s.data.total.toLocaleString('pt-BR') : s.data.items.length}</span>
                                <span class="stat-label">{s.label}</span>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </div>

        <!-- Seções de entidades -->
        <div class="container entities-sections">
            {sections.map(s => (
                <section class="entity-section">
                    <div class="entity-section__header">
                        <div class="entity-section__title">
                            <span class="entity-section__icon" style={`color: ${s.color}`} set:html={s.icon} />
                            <h2 style={`color: ${s.color}`}>{s.label}</h2>
                        </div>
                        <a class="entity-section__link" href={`/busca#${s.key}`} style={`color: ${s.color}`}>
                            Ver todos →
                        </a>
                    </div>

                    {s.data.items.length === 0 ? (
                        <div class="entity-empty">
                            <p>Nenhum(a) {s.label.toLowerCase().slice(0, -1)} cadastrado(a) ainda.</p>
                        </div>
                    ) : (
                        <div class="entity-grid">
                            {s.data.items.map((item: any) => {
                                const meta = s.meta(item);
                                const areas = item.terms?.area ?? [];
                                return (
                                    <a class="entity-card" href={`${s.href}/${item.id}/info`} style={`--accent: ${s.color}; --bg: ${s.bg}`}>
                                        <div class="entity-card__top">
                                            <h3 class="entity-card__name">{item.name}</h3>
                                            {meta && <span class="entity-card__meta">{meta}</span>}
                                        </div>
                                        {item.shortDescription && (
                                            <p class="entity-card__desc">{item.shortDescription}</p>
                                        )}
                                        {areas.length > 0 && (
                                            <div class="entity-card__tags">
                                                {areas.slice(0, 3).map((a: string) => (
                                                    <span class="entity-card__tag">{a}</span>
                                                ))}
                                            </div>
                                        )}
                                    </a>
                                );
                            })}
                        </div>
                    )}
                </section>
            ))}
        </div>

    </div>

    <style>
        .entities-page {
            font-family: 'Source Sans 3', Arial, sans-serif;
            min-height: 100vh;
            background: #f2f2f2;
        }

        .entities-header {
            background: linear-gradient(135deg, #0033a0 0%, #0056c8 100%);
            color: #fff;
            padding: 2.5rem 0 2rem;
        }

        .container {
            width: min(1180px, 92vw);
            margin: 0 auto;
        }

        .entities-back {
            display: inline-block;
            color: rgba(255,255,255,0.75);
            text-decoration: none;
            font-size: 0.875rem;
            margin-bottom: 0.75rem;
            transition: color 0.15s;
        }

        .entities-back:hover { color: #fff; }

        .entities-header h1 {
            margin: 0 0 0.4rem;
            font-size: clamp(1.6rem, 3vw, 2.4rem);
            font-weight: 700;
            line-height: 1.1;
        }

        .entities-subtitle {
            margin: 0;
            color: rgba(255,255,255,0.8);
            font-size: 1rem;
        }

        /* ── STATS ──────────────────────────────────────── */
        .entities-stats {
            background: #fff;
            border-bottom: 1px solid #e8e8e8;
            padding: 1.25rem 0;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1rem;
        }

        .stat-card {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            background: var(--bg);
            border: 1px solid color-mix(in srgb, var(--accent) 20%, transparent);
            border-radius: 8px;
            padding: 0.9rem 1rem;
        }

        .stat-icon { color: var(--accent); flex-shrink: 0; line-height: 0; }

        .stat-info { display: flex; flex-direction: column; gap: 0.1rem; }

        .stat-count {
            font-size: 1.4rem;
            font-weight: 700;
            color: var(--accent);
            line-height: 1;
        }

        .stat-label { font-size: 0.78rem; color: #555; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; }

        /* ── SECTIONS ───────────────────────────────────── */
        .entities-sections { padding: 2rem 0; display: flex; flex-direction: column; gap: 2.5rem; }

        .entity-section {
            background: #fff;
            border: 1px solid #e8e8e8;
            border-radius: 10px;
            padding: 1.5rem;
        }

        .entity-section__header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1.25rem;
        }

        .entity-section__title {
            display: flex;
            align-items: center;
            gap: 0.6rem;
        }

        .entity-section__icon { line-height: 0; }

        .entity-section__title h2 {
            margin: 0;
            font-size: 1.1rem;
            font-weight: 700;
            line-height: 1;
        }

        .entity-section__link {
            font-size: 0.82rem;
            font-weight: 700;
            text-decoration: none;
            opacity: 0.85;
        }

        .entity-section__link:hover { opacity: 1; text-decoration: underline; }

        /* ── GRID ───────────────────────────────────────── */
        .entity-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 0.875rem;
        }

        .entity-card {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
            background: var(--bg);
            border: 1px solid color-mix(in srgb, var(--accent) 18%, transparent);
            border-radius: 8px;
            padding: 1rem;
            text-decoration: none;
            color: inherit;
            transition: box-shadow 0.15s, transform 0.15s;
        }

        .entity-card:hover {
            box-shadow: 0 4px 14px rgba(0,0,0,0.09);
            transform: translateY(-2px);
        }

        .entity-card__top { display: flex; justify-content: space-between; align-items: flex-start; gap: 0.5rem; }

        .entity-card__name {
            margin: 0;
            font-size: 0.95rem;
            font-weight: 700;
            color: #1f1f1f;
            line-height: 1.3;
        }

        .entity-card__meta {
            flex-shrink: 0;
            font-size: 0.72rem;
            font-weight: 700;
            color: var(--accent);
            background: color-mix(in srgb, var(--accent) 12%, white);
            border-radius: 999px;
            padding: 0.15rem 0.5rem;
            white-space: nowrap;
        }

        .entity-card__desc {
            margin: 0;
            font-size: 0.85rem;
            color: #555;
            line-height: 1.4;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .entity-card__tags { display: flex; flex-wrap: wrap; gap: 0.3rem; }

        .entity-card__tag {
            font-size: 0.72rem;
            background: color-mix(in srgb, var(--accent) 10%, white);
            color: var(--accent);
            border-radius: 999px;
            padding: 0.15rem 0.5rem;
            border: 1px solid color-mix(in srgb, var(--accent) 20%, transparent);
        }

        /* ── EMPTY ──────────────────────────────────────── */
        .entity-empty {
            padding: 1.5rem;
            text-align: center;
            color: #888;
            font-size: 0.9rem;
            background: #fafafa;
            border-radius: 6px;
            border: 1px dashed #ddd;
        }

        /* ── RESPONSIVE ─────────────────────────────────── */
        @media (max-width: 900px) {
            .stats-grid { grid-template-columns: repeat(2, 1fr); }
            .entity-grid { grid-template-columns: repeat(2, 1fr); }
        }

        @media (max-width: 540px) {
            .stats-grid { grid-template-columns: repeat(2, 1fr); }
            .entity-grid { grid-template-columns: 1fr; }
        }
    </style>
</HomeLayout>
