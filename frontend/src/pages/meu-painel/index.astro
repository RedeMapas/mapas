---
import HomeLayout from '../../layouts/HomeLayout.astro';
---

<HomeLayout title="Meu painel — Rede Mapas">
    <div class="min-h-screen bg-base-200">
        <div id="state-loading" class="hero min-h-[60vh]" hidden>
            <div class="hero-content flex-col gap-4 text-base-content/60">
                <span class="loading loading-spinner loading-lg text-primary"></span>
                <p>Carregando seu painel…</p>
            </div>
        </div>

        <div id="state-guest" hidden>
            <div class="hero min-h-[70vh]">
                <div class="hero-content">
                    <div class="card bg-base-100 shadow-xl max-w-md w-full">
                        <div class="card-body items-center text-center">
                            <div class="text-primary mb-4">
                                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                    <circle cx="12" cy="8" r="4"/>
                                    <path d="M20 21a8 8 0 1 0-16 0"/>
                                </svg>
                            </div>
                            <h1 class="card-title text-xl text-primary">Acesso ao painel</h1>
                            <p class="text-base-content/60">Para acessar seu painel, você precisa estar autenticado.</p>
                            <div class="card-actions flex gap-3 mt-4">
                                <a class="btn btn-primary" href="/auth/login?next=/meu-painel">Fazer login</a>
                                <a class="btn btn-outline" href="/">Voltar ao início</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div id="panel-main" hidden>
            <div class="bg-gradient-to-br from-primary to-secondary text-primary-content py-6">
                <div class="container mx-auto w-full max-w-[1180px] px-[4vw]">
                    <div class="flex items-center justify-between gap-4 flex-wrap">
                        <div>
                            <p class="text-xs font-bold uppercase tracking-wider text-primary-content/60">Meu painel</p>
                            <h1 id="panel-user-name" class="text-xl md:text-2xl font-bold">…</h1>
                        </div>
                        <nav class="flex items-center gap-1" aria-label="Navegação do painel">
                            <a class="btn btn-ghost btn-sm text-primary-content/85 hover:text-primary-content" href="/entidades">Explorar</a>
                            <a class="btn btn-ghost btn-sm text-primary-content/85 hover:text-primary-content" href="/">Início</a>
                            <a class="btn btn-ghost btn-sm text-error/80 hover:text-error-content hover:bg-error/10" href="/logout">Sair</a>
                        </nav>
                    </div>
                </div>
            </div>

            <div class="container mx-auto w-full max-w-[1180px] px-[4vw] py-8 flex flex-col gap-8">

                <section>
                    <h2 class="text-xs font-bold uppercase tracking-wider text-base-content/50 mb-3">Ações rápidas</h2>
                    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
                        <a id="new-agent-link" class="card bg-base-100 shadow-sm hover:shadow-md transition-all hover:-translate-y-0.5" href="/edicao-de-agente/novo">
                            <div class="card-body items-center text-center py-5">
                                <span class="text-primary" aria-hidden="true">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/><line x1="12" y1="3" x2="12" y2="1"/><line x1="12" y1="3" x2="14" y2="3"/></svg>
                                </span>
                                <span class="text-sm font-bold">Novo agente</span>
                            </div>
                        </a>
                        <a class="card bg-base-100 shadow-sm hover:shadow-md transition-all hover:-translate-y-0.5" href="/edicao-de-espaco/novo">
                            <div class="card-body items-center text-center py-5">
                                <span class="text-primary" aria-hidden="true">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                                </span>
                                <span class="text-sm font-bold">Novo espaço</span>
                            </div>
                        </a>
                        <a class="card bg-base-100 shadow-sm hover:shadow-md transition-all hover:-translate-y-0.5" href="/edicao-de-evento/novo">
                            <div class="card-body items-center text-center py-5">
                                <span class="text-primary" aria-hidden="true">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                                </span>
                                <span class="text-sm font-bold">Novo evento</span>
                            </div>
                        </a>
                        <a class="card bg-base-100 shadow-sm hover:shadow-md transition-all hover:-translate-y-0.5" href="/gestao-de-oportunidade/novo">
                            <div class="card-body items-center text-center py-5">
                                <span class="text-primary" aria-hidden="true">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg>
                                </span>
                                <span class="text-sm font-bold">Novo edital</span>
                            </div>
                        </a>
                    </div>
                </section>

                <section class="card bg-base-100 shadow-sm" id="section-agents">
                    <div class="card-body">
                        <div class="flex items-center justify-between mb-4">
                            <h2 class="card-title text-primary text-base">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                Meus agentes
                            </h2>
                            <a class="btn btn-ghost btn-xs text-primary" href="/edicao-de-agente/novo">+ Novo agente</a>
                        </div>
                        <div id="agents-list" class="flex flex-col gap-2">
                            <div class="flex justify-center py-8"><span class="loading loading-spinner loading-sm text-primary"></span></div>
                        </div>
                    </div>
                </section>

                <section class="card bg-base-100 shadow-sm" id="section-spaces">
                    <div class="card-body">
                        <div class="flex items-center justify-between mb-4">
                            <h2 class="card-title text-accent text-base">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                                Meus espaços
                            </h2>
                            <a class="btn btn-ghost btn-xs text-accent" href="/edicao-de-espaco/novo">+ Novo espaço</a>
                        </div>
                        <div id="spaces-list" class="flex flex-col gap-2">
                            <div class="flex justify-center py-8"><span class="loading loading-spinner loading-sm text-accent"></span></div>
                        </div>
                    </div>
                </section>

                <section class="card bg-base-100 shadow-sm" id="section-events">
                    <div class="card-body">
                        <div class="flex items-center justify-between mb-4">
                            <h2 class="card-title text-warning text-base">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                                Meus eventos
                            </h2>
                            <a class="btn btn-ghost btn-xs text-warning" href="/edicao-de-evento/novo">+ Novo evento</a>
                        </div>
                        <div id="events-list" class="flex flex-col gap-2">
                            <div class="flex justify-center py-8"><span class="loading loading-spinner loading-sm text-warning"></span></div>
                        </div>
                    </div>
                </section>

                <section class="card bg-base-100 shadow-sm" id="section-opportunities">
                    <div class="card-body">
                        <div class="flex items-center justify-between mb-4">
                            <h2 class="card-title text-secondary text-base">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                                Meus editais
                            </h2>
                            <a class="btn btn-ghost btn-xs text-secondary" href="/gestao-de-oportunidade/novo">+ Novo edital</a>
                        </div>
                        <div id="opportunities-list" class="flex flex-col gap-2">
                            <div class="flex justify-center py-8"><span class="loading loading-spinner loading-sm text-secondary"></span></div>
                        </div>
                    </div>
                </section>

            </div>
        </div>
    </div>

    <script is:inline>
        document.getElementById('state-loading').removeAttribute('hidden');
    </script>

    <script>
        const API_HEADERS = { 'X-Requested-With': 'XMLHttpRequest' };

        async function apiFetch(url) {
            const res = await fetch(url, { credentials: 'same-origin', headers: API_HEADERS });
            if (!res.ok) return null;
            const data = await res.json();
            if (data && data.error) return null;
            return data;
        }

        function formatStatus(status) {
            if (status === 1) return '<span class="badge badge-success badge-sm">Publicado</span>';
            if (status === 0) return '<span class="badge badge-warning badge-sm">Rascunho</span>';
            if (status === -9) return '<span class="badge badge-error badge-sm">Desativado</span>';
            if (status === -10) return '<span class="badge badge-ghost badge-sm">Lixeira</span>';
            return '';
        }

        function renderEntityList(containerId, items, config) {
            const container = document.getElementById(containerId);
            if (!items || items.length === 0) {
                container.innerHTML = `
                    <div class="alert alert-info">
                        <p>Nenhum(a) ${config.label} cadastrado(a) ainda.</p>
                        <a class="btn btn-primary btn-sm" href="${config.newUrl}">Criar ${config.label}</a>
                    </div>`;
                return;
            }

            container.innerHTML = items.map(item => {
                const editUrl = config.editUrl(item);
                const viewUrl = config.viewUrl(item);
                return `
                    <div class="flex items-center justify-between gap-4 p-3 rounded-lg bg-base-200 hover:bg-base-300 transition">
                        <div class="flex flex-col gap-1 min-w-0 flex-1">
                            <div class="flex items-center gap-2 flex-wrap">
                                <span class="text-sm font-bold truncate">${escHtml(item.name ?? '—')}</span>
                                ${item.type?.name ? `<span class="badge badge-sm badge-primary">${escHtml(item.type.name)}</span>` : ''}
                            </div>
                            <div class="flex items-center gap-2 flex-wrap">
                                ${formatStatus(item.status)}
                                ${item.shortDescription ? `<span class="text-xs text-base-content/60">${escHtml(item.shortDescription.slice(0, 80))}${item.shortDescription.length > 80 ? '…' : ''}</span>` : ''}
                            </div>
                        </div>
                        <div class="flex gap-1 shrink-0">
                            <a class="btn btn-ghost btn-xs" href="${viewUrl}" target="_blank" rel="noopener" title="Ver">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                Ver
                            </a>
                            <a class="btn btn-primary btn-xs" href="${editUrl}" title="Editar">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                Editar
                            </a>
                        </div>
                    </div>`;
            }).join('');
        }

        function escHtml(str) {
            return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
        }

        async function initPanel() {
            const agents = await apiFetch('/api/agent/find?@select=id,name,type,status,shortDescription&user=EQ(@me)&@limit=50&@order=name+ASC&status=EQ(1)');

            if (agents === null) {
                const allAgents = await apiFetch('/api/agent/find?@select=id,name,userId&user=EQ(@me)&@limit=1&status=GTE(-10)');
                if (!allAgents || allAgents.length === 0) {
                    document.getElementById('state-loading').hidden = true;
                    document.getElementById('state-guest').hidden = false;
                    return;
                }
            }

            const profileAgents = await apiFetch('/api/agent/find?@select=id,name,userId&user=EQ(@me)&@limit=1&@order=id+ASC&status=GTE(-10)');
            const userId = profileAgents?.[0]?.userId;
            const profileName = profileAgents?.[0]?.name;

            document.getElementById('panel-user-name').textContent = profileName ?? 'Usuário';

            document.getElementById('state-loading').hidden = true;
            document.getElementById('panel-main').hidden = false;

            const userFilter = userId ? `user=EQ(${userId})` : 'user=EQ(@me)';
            const baseFields = 'id,name,type,status,shortDescription';
            const statusFilter = 'status=GTE(-9)';

            const [myAgents, mySpaces, myEvents, myOpps] = await Promise.all([
                apiFetch(`/api/agent/find?@select=${baseFields}&${userFilter}&${statusFilter}&@limit=50&@order=name+ASC`),
                apiFetch(`/api/space/find?@select=${baseFields}&${userFilter}&${statusFilter}&@limit=50&@order=name+ASC`),
                apiFetch(`/api/event/find?@select=${baseFields},startsOn&${userFilter}&${statusFilter}&@limit=50&@order=name+ASC`),
                apiFetch(`/api/opportunity/find?@select=${baseFields},registrationFrom,registrationTo&${userFilter}&${statusFilter}&@limit=50&@order=name+ASC`),
            ]);

            renderEntityList('agents-list', myAgents, {
                label: 'agente',
                newUrl: '/edicao-de-agente/novo',
                editUrl: item => `/agente/${item.id}/editar`,
                viewUrl: item => `/agente/${item.id}/info`,
            });

            renderEntityList('spaces-list', mySpaces, {
                label: 'espaço',
                newUrl: '/edicao-de-espaco/novo',
                editUrl: item => item.editUrl ?? `/edicao-de-espaco/${item.id}`,
                viewUrl: item => `/espaco/${item.id}/info`,
            });

            renderEntityList('events-list', myEvents, {
                label: 'evento',
                newUrl: '/edicao-de-evento/novo',
                editUrl: item => item.editUrl ?? `/edicao-de-evento/${item.id}`,
                viewUrl: item => `/evento/${item.id}/info`,
            });

            renderEntityList('opportunities-list', myOpps, {
                label: 'edital',
                newUrl: '/gestao-de-oportunidade/novo',
                editUrl: item => item.editUrl ?? `/gestao-de-oportunidade/${item.id}`,
                viewUrl: item => `/oportunidade/${item.id}`,
            });
        }

        initPanel().catch(err => {
            console.error('[panel]', err);
            document.getElementById('state-loading').hidden = true;
            document.getElementById('state-guest').hidden = false;
        });
    </script>
</HomeLayout>
