---
import { getDb } from '../../lib/ingestor/db.ts'
import '../../styles/global.css'

let db
let stats = { total: 0, pending: 0, auto_approved: 0, approved: 0, rejected: 0, exported: 0 }
let lastRun: { started_at: string; status: string; events_fetched: number; events_new: number } | null = null
let isRunning = false

try {
  db = getDb()

  const rows = db.prepare(`
    SELECT review_status, COUNT(*) as count FROM events GROUP BY review_status
  `).all() as Array<{ review_status: string; count: number }>

  for (const row of rows) {
    stats[row.review_status as keyof typeof stats] = row.count
    stats.total += row.count
  }

  const exportedCount = db.prepare(`
    SELECT COUNT(*) as count FROM events WHERE import_status = 'exported'
  `).get() as { count: number }
  stats.exported = exportedCount.count

  lastRun = db.prepare(`
    SELECT started_at, status, events_fetched, events_new
    FROM crawl_runs WHERE platform = 'sympla'
    ORDER BY started_at DESC LIMIT 1
  `).get() as typeof lastRun

  const staleThreshold = new Date(Date.now() - 2 * 60 * 60 * 1000).toISOString()
  const running = db.prepare(`
    SELECT id FROM crawl_runs
    WHERE platform = 'sympla' AND status = 'running' AND started_at > ?
  `).get(staleThreshold)
  isRunning = !!running
} catch (e) {
  console.error('[ingestor/index] DB error:', e)
}

function formatDate(iso: string) {
  return new Date(iso).toLocaleString('pt-BR', { timeZone: 'America/Fortaleza' })
}
---

<html lang="pt-br" data-theme="light">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Ingestor de Eventos — Rede Mapas</title>
</head>
<body class="bg-base-200 min-h-screen">
  <div class="navbar bg-primary text-primary-content px-6">
    <div class="navbar-start">
      <h1 class="text-lg font-semibold">Ingestor de Eventos</h1>
    </div>
    <div class="navbar-end gap-2">
      <a href="/ingestor" class="btn btn-ghost btn-sm text-primary-content/85">Dashboard</a>
      <a href="/ingestor/eventos" class="btn btn-ghost btn-sm text-primary-content/85">Eventos</a>
      <a href="/ingestor/exportar" class="btn btn-ghost btn-sm text-primary-content/85">Exportar CSV</a>
    </div>
  </div>

  <main class="max-w-4xl mx-auto p-4">
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-8">
      <div class="stat bg-base-100 rounded-box shadow-sm text-center p-4">
        <div class="stat-value text-2xl text-primary">{stats.total}</div>
        <div class="stat-title text-xs">Total</div>
      </div>
      <div class="stat bg-base-100 rounded-box shadow-sm text-center p-4">
        <div class="stat-value text-2xl text-warning">{stats.pending}</div>
        <div class="stat-title text-xs">Pendentes</div>
      </div>
      <div class="stat bg-base-100 rounded-box shadow-sm text-center p-4">
        <div class="stat-value text-2xl">{stats.auto_approved}</div>
        <div class="stat-title text-xs">Auto-aprovados</div>
      </div>
      <div class="stat bg-base-100 rounded-box shadow-sm text-center p-4">
        <div class="stat-value text-2xl text-success">{stats.approved}</div>
        <div class="stat-title text-xs">Aprovados</div>
      </div>
      <div class="stat bg-base-100 rounded-box shadow-sm text-center p-4">
        <div class="stat-value text-2xl text-error">{stats.rejected}</div>
        <div class="stat-title text-xs">Rejeitados</div>
      </div>
      <div class="stat bg-base-100 rounded-box shadow-sm text-center p-4">
        <div class="stat-value text-2xl">{stats.exported}</div>
        <div class="stat-title text-xs">Exportados</div>
      </div>
    </div>

    <div class="card bg-base-100 shadow-sm">
      <div class="card-body">
        <h2 class="card-title text-sm">Última sincronização</h2>
        {lastRun ? (
          <div class="flex items-center gap-3 text-sm">
            <span class={`badge ${lastRun.status === 'done' ? 'badge-success' : lastRun.status === 'running' ? 'badge-warning' : 'badge-error'}`}>{lastRun.status}</span>
            <span>{formatDate(lastRun.started_at)}</span>
            <span class="text-base-content/60">— {lastRun.events_fetched} eventos, {lastRun.events_new} novos</span>
          </div>
        ) : (
          <p class="text-base-content/50 text-sm">Nenhuma sincronização realizada ainda.</p>
        )}
        <div class="card-actions justify-start mt-4">
          <button id="sync-btn" class="btn btn-primary btn-sm" disabled={isRunning}>
            {isRunning ? 'Sincronizando...' : 'Sincronizar agora'}
          </button>
          <a href="/ingestor/eventos" class="btn btn-ghost btn-sm">Ver eventos</a>
        </div>
      </div>
    </div>
  </main>

  <script>
    const btn = document.getElementById('sync-btn')
    btn?.addEventListener('click', async () => {
      btn.disabled = true
      btn.textContent = 'Iniciando...'
      try {
        const res = await fetch('/api/ingestor/sync', { method: 'POST' })
        const data = await res.json()
        if (res.ok) {
          btn.textContent = 'Sincronizando...'
          setTimeout(() => location.reload(), 3000)
        } else {
          alert(data.error ?? 'Erro ao iniciar sincronização')
          btn.disabled = false
          btn.textContent = 'Sincronizar agora'
        }
      } catch {
        alert('Erro de rede')
        btn.disabled = false
        btn.textContent = 'Sincronizar agora'
      }
    })
  </script>
</body>
</html>
