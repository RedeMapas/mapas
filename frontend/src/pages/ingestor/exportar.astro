---
import { getDb } from '../../lib/ingestor/db.ts'
import '../../styles/global.css'

let pendingCount = 0
let exportHistory: Array<{ exported_at: string; event_count: number }> = []

try {
  const db = getDb()
  const result = db.prepare(`
    SELECT COUNT(*) as n FROM events
    WHERE review_status IN ('approved', 'auto_approved') AND import_status = 'pending'
  `).get() as { n: number }
  pendingCount = result.n

  exportHistory = db.prepare(`
    SELECT exported_at, event_count FROM export_runs ORDER BY exported_at DESC LIMIT 10
  `).all() as typeof exportHistory
} catch (e) {
  console.error('[exportar] DB error:', e)
}

function formatDate(iso: string) {
  return new Date(iso).toLocaleString('pt-BR', { timeZone: 'America/Fortaleza' })
}
---

<html lang="pt-br" data-theme="light">
<head>
  <meta charset="utf-8" />
  <title>Exportar CSV — Ingestor</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
</head>
<body class="bg-base-200 min-h-screen">
  <div class="navbar bg-primary text-primary-content">
    <div class="flex-1">
      <span class="text-lg font-semibold">Ingestor de Eventos</span>
    </div>
    <div class="flex-none gap-4">
      <a href="/ingestor" class="link link-hover text-sm opacity-85">Dashboard</a>
      <a href="/ingestor/eventos" class="link link-hover text-sm opacity-85">Eventos</a>
      <a href="/ingestor/exportar" class="link link-hover text-sm opacity-85">Exportar CSV</a>
    </div>
  </div>

  <main class="max-w-3xl mx-auto p-4 mt-6 flex flex-col gap-5">
    <div class="card bg-base-100 shadow-sm">
      <div class="card-body">
        <h2 class="card-title text-base">Exportar para Mapas Culturais</h2>
        <div class="text-4xl font-bold text-success">{pendingCount}</div>
        <p class="text-base-content/60 text-sm mt-1 mb-4">
          evento{pendingCount !== 1 ? 's' : ''} aprovado{pendingCount !== 1 ? 's' : ''} prontos para exportação
        </p>

        {pendingCount > 0 ? (
          <a href="/api/ingestor/export" class="btn btn-success" id="export-btn">
            ↓ Baixar CSV (mapas-export-*.csv)
          </a>
        ) : (
          <button class="btn btn-success btn-disabled" disabled>
            Nenhum evento pendente de exportação
          </button>
        )}

        <p class="text-xs text-base-content/40 mt-3">
          O download inclui todos os eventos com status "aprovado" ou "auto-aprovado" ainda não exportados.
          Após o download, eles são marcados como exportados e não aparecem no próximo CSV.
        </p>
      </div>
    </div>

    <div class="card bg-base-100 shadow-sm">
      <div class="card-body">
        <h2 class="card-title text-base">Histórico de exportações</h2>
        {exportHistory.length === 0 ? (
          <p class="text-base-content/40 italic">Nenhuma exportação realizada ainda.</p>
        ) : (
          <div class="overflow-x-auto">
            <table class="table table-sm">
              <thead>
                <tr>
                  <th>Data / Hora</th>
                  <th>Eventos exportados</th>
                </tr>
              </thead>
              <tbody>
                {exportHistory.map(r => (
                  <tr>
                    <td>{formatDate(r.exported_at)}</td>
                    <td>{r.event_count}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </div>
    </div>
  </main>
</body>
</html>
