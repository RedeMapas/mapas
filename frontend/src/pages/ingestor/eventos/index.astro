---
import { getDb } from '../../../lib/ingestor/db.ts'
import '../../../styles/global.css'

const tab = Astro.url.searchParams.get('tab') ?? 'pending'
const search = Astro.url.searchParams.get('q') ?? ''

const validTabs = ['all', 'pending', 'auto_approved', 'approved', 'rejected'] as const
type Tab = typeof validTabs[number]
const activeTab = (validTabs.includes(tab as Tab) ? tab : 'pending') as Tab

let events: Array<Record<string, unknown>> = []
let total = 0

try {
  const db = getDb()

  const statusFilter = activeTab === 'all' ? null : activeTab
  const searchFilter = search ? `%${search}%` : null

  let where = 'WHERE 1=1'
  const params: unknown[] = []

  if (statusFilter) {
    where += ' AND review_status = ?'
    params.push(statusFilter)
  }
  if (searchFilter) {
    where += ' AND (title LIKE ? OR match_note LIKE ?)'
    params.push(searchFilter, searchFilter)
  }

  total = (db.prepare(`SELECT COUNT(*) as n FROM events ${where}`).get(...params) as { n: number }).n
  events = db.prepare(
    `SELECT id, title, start_at, end_at, match_status, match_score, match_note,
            review_status, import_status, avatar_url, source_url
     FROM events ${where}
     ORDER BY start_at ASC
     LIMIT 50`
  ).all(...params) as typeof events
} catch (e) {
  console.error('[eventos/index] DB error:', e)
}

const TABS: Array<{ key: Tab; label: string }> = [
  { key: 'all', label: 'Todos' },
  { key: 'pending', label: 'Pendentes' },
  { key: 'auto_approved', label: 'Auto-aprovados' },
  { key: 'approved', label: 'Aprovados' },
  { key: 'rejected', label: 'Rejeitados' },
]

function matchBadge(status: string) {
  if (status === 'matched') return { cls: 'badge-success', label: '✓ matched' }
  if (status === 'suggested') return { cls: 'badge-warning', label: '~ sugerido' }
  return { cls: 'badge-ghost', label: '? pendente' }
}

function importBadge(status: string) {
  if (status === 'imported') return { cls: 'badge-success', label: '✓ importado' }
  if (status === 'failed') return { cls: 'badge-error', label: '✗ falhou' }
  if (status === 'exported') return { cls: 'badge-info', label: 'exportado' }
  return { cls: 'badge-ghost', label: 'pendente' }
}

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric', timeZone: 'America/Fortaleza' })
}
---

<html lang="pt-br" data-theme="light">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Eventos — Ingestor</title>
</head>
<body class="bg-base-200 min-h-screen">
  <div class="navbar bg-primary text-primary-content px-6">
    <div class="navbar-start">
      <h1 class="text-lg font-semibold">Ingestor de Eventos</h1>
    </div>
    <div class="navbar-end gap-2">
      <a href="/ingestor" class="btn btn-ghost btn-sm text-primary-content/85">Dashboard</a>
      <a href="/ingestor/eventos" class="btn btn-ghost btn-sm text-primary-content/85">Eventos</a>
      <a href="/ingestor/exportar" class="btn btn-ghost btn-sm text-primary-content/85">Exportar CSV</a>
    </div>
  </div>

  <main class="max-w-4xl mx-auto p-4">
    <div class="flex gap-2 flex-wrap mb-4">
      {TABS.map(t => (
        <a href={`?tab=${t.key}${search ? `&q=${encodeURIComponent(search)}` : ''}`}
           class={`btn btn-sm ${activeTab === t.key ? 'btn-primary' : 'btn-ghost bg-base-100'}`}>
          {t.label}
        </a>
      ))}
    </div>

    <div class="mb-4">
      <input id="search" type="search" placeholder="Buscar por título..." value={search}
             class="input input-bordered w-full" />
    </div>

    <div class="flex justify-between items-center bg-base-100 rounded-box p-3 shadow-sm mb-4 text-sm">
      <label class="flex items-center gap-2 cursor-pointer">
        <input type="checkbox" id="select-all-checkbox" class="checkbox checkbox-sm checkbox-primary" />
        <span class="text-base-content/60">{total} evento{total !== 1 ? 's' : ''}</span>
      </label>
      <div class="flex gap-2">
        <button id="bulk-import-btn" class="btn btn-info btn-sm hidden">Importar selecionados (0)</button>
        <button id="bulk-approve-btn" class="btn btn-success btn-sm hidden">Aprovar selecionados (0)</button>
      </div>
    </div>

    {events.length === 0 ? (
      <div class="hero min-h-[30vh]">
        <div class="hero-content text-base-content/50">Nenhum evento nesta categoria.</div>
      </div>
    ) : (
      <div class="flex flex-col gap-3" id="event-list">
        {events.map(evt => {
          const badge = matchBadge(String(evt.match_status))
          return (
            <div class="card bg-base-100 shadow-sm" data-id={evt.id}>
              <div class="card-body flex-row items-start gap-4 p-4">
                <input type="checkbox" class="checkbox checkbox-sm checkbox-primary mt-1 event-checkbox" data-id={evt.id} />
                <div class="flex-1 min-w-0">
                  <p class="font-semibold text-sm">{String(evt.title)}</p>
                  <div class="flex gap-2 flex-wrap mt-1">
                    <span class="text-xs text-base-content/60">{formatDate(String(evt.start_at))}</span>
                    <span class={`badge badge-sm ${badge.cls}`}>{badge.label}</span>
                    {evt.match_score ? <span class="text-xs text-base-content/50">score: {evt.match_score}</span> : null}
                    {evt.review_status === 'auto_approved' && <span class="badge badge-success badge-sm">auto-aprovado</span>}
                    {(() => {
                      const ib = importBadge(String(evt.import_status))
                      return <span class={`badge badge-sm ${ib.cls}`}>{ib.label}</span>
                    })()}
                  </div>
                  {evt.match_note && <p class="text-xs text-error mt-1">⚠ {String(evt.match_note)}</p>}
                </div>
                <a href={`/ingestor/eventos/${evt.id}`} class="btn btn-ghost btn-sm text-primary">Editar →</a>
              </div>
            </div>
          )
        })}
      </div>
    )}
  </main>

  <script>
    const searchInput = document.getElementById('search') as HTMLInputElement
    searchInput?.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter') {
        const url = new URL(location.href)
        url.searchParams.set('q', searchInput.value)
        url.searchParams.delete('page')
        location.href = url.toString()
      }
    })

    const bulkApproveBtn = document.getElementById('bulk-approve-btn') as HTMLButtonElement
    const bulkImportBtn = document.getElementById('bulk-import-btn') as HTMLButtonElement
    const selectAllCheckbox = document.getElementById('select-all-checkbox') as HTMLInputElement
    const checkboxes = document.querySelectorAll<HTMLInputElement>('.event-checkbox')

    function updateBulkBar() {
      const checked = [...checkboxes].filter(c => c.checked)
      const count = checked.length
      if (count > 0) {
        bulkApproveBtn.classList.remove('hidden')
        bulkApproveBtn.textContent = `Aprovar selecionados (${count})`
        bulkImportBtn.classList.remove('hidden')
        bulkImportBtn.textContent = `Importar selecionados (${count})`
      } else {
        bulkApproveBtn.classList.add('hidden')
        bulkImportBtn.classList.add('hidden')
      }
    }

    selectAllCheckbox?.addEventListener('change', () => {
      checkboxes.forEach(cb => { cb.checked = selectAllCheckbox.checked })
      updateBulkBar()
    })

    checkboxes.forEach(cb => cb.addEventListener('change', updateBulkBar))

    bulkApproveBtn?.addEventListener('click', async () => {
      const checked = [...checkboxes].filter(c => c.checked)
      const ids = checked.map(c => Number(c.dataset['id']))
      if (!confirm(`Você está aprovando ${ids.length} evento${ids.length !== 1 ? 's' : ''}. Confirmar?`)) return
      bulkApproveBtn.disabled = true
      try {
        const res = await fetch('/api/ingestor/events/bulk-approve', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ ids }),
        })
        const data = await res.json()
        if (res.ok) {
          alert(`${data.approved} evento${data.approved !== 1 ? 's' : ''} aprovado${data.approved !== 1 ? 's' : ''}.`)
          location.reload()
        } else {
          alert(data.error ?? 'Erro ao aprovar')
        }
      } catch {
        alert('Erro de rede')
      } finally {
        bulkApproveBtn.disabled = false
      }
    })

    bulkImportBtn?.addEventListener('click', async () => {
      const checked = [...checkboxes].filter(c => c.checked)
      const ids = checked.map(c => Number(c.dataset['id']))
      if (!confirm(`Importar ${ids.length} evento${ids.length !== 1 ? 's' : ''} para o Mapas?`)) return
      bulkImportBtn.disabled = true
      try {
        const res = await fetch('/api/ingestor/events/import', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ ids }),
        })
        const data = await res.json()
        if (res.ok) {
          alert(`Importados: ${data.imported}, Falhas: ${data.failed}`)
          location.reload()
        } else {
          alert(data.error ?? 'Erro ao importar')
        }
      } catch {
        alert('Erro de rede')
      } finally {
        bulkImportBtn.disabled = false
      }
    })
  </script>
</body>
</html>
