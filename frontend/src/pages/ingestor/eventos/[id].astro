---
import { getDb } from '../../../lib/ingestor/db.ts'
import '../../../styles/global.css'

const { id } = Astro.params
const db = getDb()

const event = db.prepare('SELECT * FROM events WHERE id = ?').get(Number(id)) as Record<string, unknown> | null
if (!event) {
  return Astro.redirect('/ingestor/eventos')
}

const venues = db.prepare('SELECT mapas_space_id, name, city FROM venue_cache ORDER BY name').all() as Array<{ mapas_space_id: number; name: string; city: string }>

function formatDate(iso: string) {
  return new Date(iso).toLocaleString('pt-BR', { timeZone: 'America/Fortaleza' })
}

const matchBadgeClass: Record<string, string> = {
  matched: 'badge badge-success',
  suggested: 'badge badge-warning',
  pending: 'badge badge-ghost',
}
---

<html lang="pt-br" data-theme="light">
<head>
  <meta charset="utf-8" />
  <title>{String(event.title)} — Ingestor</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
</head>
<body class="bg-base-200 min-h-screen">
  <div class="navbar bg-primary text-primary-content">
    <div class="flex-1">
      <span class="text-lg font-semibold">Ingestor de Eventos</span>
    </div>
    <div class="flex-none gap-4">
      <a href="/ingestor" class="link link-hover text-sm opacity-85">Dashboard</a>
      <a href="/ingestor/eventos" class="link link-hover text-sm opacity-85">← Eventos</a>
      <a href="/ingestor/exportar" class="link link-hover text-sm opacity-85">Exportar CSV</a>
    </div>
  </div>

  <main class="max-w-3xl mx-auto p-4 mt-6 flex flex-col gap-5">
    <div class="card bg-base-100 shadow-sm">
      <div class="card-body">
        <h2 class="card-title text-base">Informações do Evento</h2>
        <div class="mb-3">
          <label class="label"><span class="label-text">Título</span></label>
          <div class="bg-base-200 rounded-lg p-2 text-sm">{String(event.title)}</div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="label"><span class="label-text">Início</span></label>
            <div class="bg-base-200 rounded-lg p-2 text-sm">{formatDate(String(event.start_at))}</div>
          </div>
          <div>
            <label class="label"><span class="label-text">Fim</span></label>
            <div class="bg-base-200 rounded-lg p-2 text-sm">{formatDate(String(event.end_at))}</div>
          </div>
        </div>
        <div class="mt-3">
          <label class="label"><span class="label-text">Link Sympla</span></label>
          <div class="bg-base-200 rounded-lg p-2 text-sm">
            <a href={String(event.source_url)} target="_blank" rel="noopener" class="link link-primary">
              {String(event.source_url)}
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class="card bg-base-100 shadow-sm">
      <div class="card-body">
        <h2 class="card-title text-base">Matching de Local</h2>
        <div class="flex flex-wrap gap-3 items-center text-sm mb-3">
          <span>Status: <span class={matchBadgeClass[String(event.match_status)] ?? 'badge badge-ghost'}>{String(event.match_status)}</span></span>
          <span>Score: <span class="font-bold">{String(event.match_score ?? 0)}</span>/100</span>
          {event.match_note && <span class="text-error">⚠ {String(event.match_note)}</span>}
        </div>

        <label class="label"><span class="label-text">Selecionar local no Mapas (busca por nome)</span></label>
        <div class="relative">
          <input
            id="venue-search-input"
            type="text"
            class="input input-bordered w-full"
            placeholder="Digite o nome do espaço..."
            autocomplete="off"
            value={event.mapas_space_id ? (venues.find(v => v.mapas_space_id === event.mapas_space_id)?.name ?? '') : ''}
          />
          <ul class="absolute left-0 right-0 bg-base-100 border border-base-300 rounded-lg max-h-52 overflow-y-auto z-10 hidden" id="venue-dropdown"></ul>
        </div>
        <input type="hidden" id="selected-space-id" value={String(event.mapas_space_id ?? '')} />
      </div>
    </div>

    <div class="card bg-base-100 shadow-sm">
      <div class="card-body">
        <h2 class="card-title text-base">Campos Editáveis</h2>
        <div class="mb-3">
          <label class="label"><span class="label-text">Descrição curta (obrigatório para auto-aprovação)</span></label>
          <textarea id="field-description_short" class="textarea textarea-bordered w-full min-h-20">{String(event.description_short ?? '')}</textarea>
        </div>
        <div class="mb-3">
          <label class="label"><span class="label-text">Descrição longa</span></label>
          <textarea id="field-description_long" class="textarea textarea-bordered w-full" rows="4">{String(event.description_long ?? '')}</textarea>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="label"><span class="label-text">Preço</span></label>
            <input type="text" id="field-price" class="input input-bordered w-full" value={String(event.price ?? '')} />
          </div>
          <div>
            <label class="label"><span class="label-text">PROPRIETARIO (ID do agente no Mapas)</span></label>
            <input type="text" id="field-proprietario" class="input input-bordered w-full" value={String(event.proprietario ?? '')} />
          </div>
        </div>
        <div class="mt-4">
          <button class="btn btn-primary" id="save-btn">Salvar</button>
        </div>
      </div>
    </div>

    <div class="card bg-base-100 shadow-sm">
      <div class="card-body">
        <h2 class="card-title text-base">Ações</h2>
        <div class="flex flex-wrap gap-3 items-center text-sm mb-3">
          <span>Status de revisão: <span class="font-bold">{String(event.review_status)}</span></span>
          <span>Import: <span class="font-bold">{String(event.import_status)}</span></span>
        </div>
        <div class="flex flex-wrap gap-3">
          {(event.review_status === 'approved' || event.review_status === 'auto_approved') && event.import_status === 'pending' && event.mapas_space_id && (
            <button class="btn btn-info" id="import-btn">Importar para Mapas</button>
          )}
          {event.review_status !== 'approved' && event.review_status !== 'auto_approved' && (
            <button class="btn btn-success" id="approve-btn">✓ Aprovar</button>
          )}
          {event.review_status !== 'rejected' && (
            <button class="btn btn-error" id="reject-btn">✗ Rejeitar</button>
          )}
          <button class="btn btn-ghost" onclick="history.back()">← Voltar</button>
        </div>
        <div class="flex flex-wrap gap-2 mt-2">
          {event.import_status === 'imported' && (
            <span class="badge badge-success">✓ Importado</span>
          )}
          {event.import_status === 'failed' && (
            <span class="badge badge-error">✗ Falhou</span>
          )}
        </div>
      </div>
    </div>
  </main>

  <script define:vars={{ venues, eventId: event.id }}>
    const venueInput = document.getElementById('venue-search-input')
    const dropdown = document.getElementById('venue-dropdown')
    const selectedSpaceInput = document.getElementById('selected-space-id')

    venueInput?.addEventListener('input', () => {
      const q = venueInput.value.toLowerCase().trim()
      if (q.length < 2) { dropdown.classList.add('hidden'); return }

      const matches = venues.filter(v =>
        v.name.toLowerCase().includes(q) || v.city.toLowerCase().includes(q)
      ).slice(0, 20)

      dropdown.innerHTML = matches.map(v =>
        `<li class="px-3 py-2 cursor-pointer text-sm hover:bg-base-200" data-id="${v.mapas_space_id}">${v.name} <small class="text-base-content/50">${v.city}</small></li>`
      ).join('')
      dropdown.classList.toggle('hidden', matches.length === 0)
    })

    dropdown?.addEventListener('click', async (e) => {
      const opt = e.target.closest('li[data-id]')
      if (!opt) return
      const spaceId = opt.dataset.id
      venueInput.value = opt.querySelector('small') ? opt.childNodes[0].textContent.trim() : opt.textContent.trim()
      selectedSpaceInput.value = spaceId
      dropdown.classList.add('hidden')

      const res = await fetch(`/api/ingestor/events/${eventId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ mapas_space_id: Number(spaceId) }),
      })
      if (res.ok) location.reload()
      else alert('Erro ao salvar local')
    })

    document.addEventListener('click', (e) => {
      if (!venueInput.contains(e.target) && !dropdown.contains(e.target)) {
        dropdown.classList.add('hidden')
      }
    })

    document.getElementById('save-btn')?.addEventListener('click', async () => {
      const body = {
        description_short: document.getElementById('field-description_short').value || null,
        description_long: document.getElementById('field-description_long').value || null,
        price: document.getElementById('field-price').value || null,
        proprietario: document.getElementById('field-proprietario').value || null,
      }
      const res = await fetch(`/api/ingestor/events/${eventId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      })
      if (res.ok) location.reload()
      else alert('Erro ao salvar')
    })

    document.getElementById('approve-btn')?.addEventListener('click', async () => {
      const res = await fetch(`/api/ingestor/events/${eventId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'approve' }),
      })
      if (res.ok) location.reload()
      else alert('Erro ao aprovar')
    })

    document.getElementById('reject-btn')?.addEventListener('click', async () => {
      if (!confirm('Rejeitar este evento?')) return
      const res = await fetch(`/api/ingestor/events/${eventId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'reject' }),
      })
      if (res.ok) history.back()
      else alert('Erro ao rejeitar')
    })

    document.getElementById('import-btn')?.addEventListener('click', async () => {
      const btn = document.getElementById('import-btn')
      btn.disabled = true
      try {
        const res = await fetch(`/api/ingestor/events/${eventId}/import`, { method: 'POST' })
        const data = await res.json()
        if (res.ok) {
          alert(`Evento importado! ID no Mapas: ${data.mapasEventId}`)
          location.reload()
        } else {
          alert(data.error ?? 'Erro ao importar')
        }
      } catch {
        alert('Erro de rede')
      } finally {
        btn.disabled = false
      }
    })
  </script>
</body>
</html>
