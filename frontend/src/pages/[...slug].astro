---
import Base from '../layouts/Base.astro';

const slug = Astro.params.slug;
const api = import.meta.env.PHP_API_URL;

let entity = null;
if (slug) {
    const parts = slug.split('/');
    try {
        const res = await fetch(`${api}/api/${parts[0]}?@select=id,name,type,shortDescription`);
        if (res.ok) entity = await res.json();
    } catch {}
}
---

<Base title={`MapaCultural${entity?.name ? ' - ' + entity.name : ''}`}>
    <main>
        {entity ? (
            <div class="card bg-base-100 shadow-sm">
                <div class="card-body">
                    <h1 class="card-title">{entity.name}</h1>
                    <p class="text-base-content/70">{entity.shortDescription}</p>
                </div>
            </div>
        ) : (
            <div class="hero min-h-[40vh]">
                <div class="hero-content text-center">
                    <div>
                        <h1 class="text-2xl font-bold">MapaCultural - Astro Frontend</h1>
                        <p class="text-base-content/60 mt-2">Página não encontrada: /{slug}</p>
                    </div>
                </div>
            </div>
        )}
    </main>
</Base>
