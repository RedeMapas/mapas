---
import HomeLayout from '../layouts/HomeLayout.astro';

interface Props {
    title?: string;
}
const { title = 'Erro — Rede Mapas' } = Astro.props;
---

<HomeLayout title={title}>
    <div class="hero min-h-screen bg-base-200">
        <div class="hero-content">
            <div class="text-center">
                <p class="text-6xl font-bold text-error" aria-hidden="true">500</p>
                <h1 class="text-2xl font-bold mt-4">Ocorreu um erro inesperado</h1>
                <p class="text-base-content/60 mt-2">Desculpe, algo deu errado. Tente novamente em alguns instantes.</p>
                <div class="flex gap-3 justify-center flex-wrap mt-6">
                    <a class="btn btn-primary" href="/">← Voltar ao início</a>
                    <button class="btn btn-outline btn-primary" onclick="window.location.reload()">Tentar novamente</button>
                </div>
            </div>
        </div>
    </div>
</HomeLayout>
