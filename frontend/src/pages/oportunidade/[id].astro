---
import HomeLayout from '../../layouts/HomeLayout.astro';

const { id } = Astro.params;
const phpUrl = import.meta.env.PHP_API_URL || '';

const fields = 'id,name,shortDescription,longDescription,registrationFrom,registrationTo,status,ownerEntity,type';
let opp: any = null;
let notFound = false;

try {
    const res = await fetch(`${phpUrl}/api/opportunity/${id}?@select=${fields}`);
    if (res.status === 404) {
        notFound = true;
    } else if (res.ok) {
        opp = await res.json();
    }
} catch (_) {}

function parseDate(val: any): Date | null {
    if (!val) return null;
    const str = typeof val === 'object' ? val.date : val;
    return str ? new Date(str) : null;
}

function formatDate(val: any): string {
    const d = parseDate(val);
    if (!d) return '—';
    return d.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' });
}

function isOpen(opp: any): boolean {
    const now = new Date();
    const from = parseDate(opp?.registrationFrom);
    const to = parseDate(opp?.registrationTo);
    return (!from || now >= from) && (!to || now <= to);
}

const title = opp ? `${opp.name} — Rede Mapas` : 'Edital não encontrado — Rede Mapas';
---

<HomeLayout title={title}>
    <div class="bg-base-200 min-h-screen py-8">
        <div class="container mx-auto w-full max-w-[1180px] px-[4vw]">
            <div class="breadcrumbs text-sm mb-6">
                <ul>
                    <li><a href="/" class="text-primary hover:underline">Início</a></li>
                    <li><a href="/entidades" class="text-primary hover:underline">Editais</a></li>
                    <li class="font-semibold truncate max-w-[240px]">{opp?.name ?? 'Edital'}</li>
                </ul>
            </div>

            {notFound || !opp ? (
                <div class="hero min-h-[40vh]">
                    <div class="hero-content">
                        <div class="text-center">
                            <p class="text-5xl mb-4" aria-hidden="true">📄</p>
                            <h1 class="text-2xl font-bold">Edital não encontrado</h1>
                            <p class="text-base-content/60 mt-2">O edital com ID <strong>{id}</strong> não existe ou foi removido.</p>
                            <a class="btn btn-primary mt-6" href="/entidades">← Voltar para editais</a>
                        </div>
                    </div>
                </div>
            ) : (
                <div class="grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-6 items-start">

                    <main class="flex flex-col gap-6">
                        <div class="card bg-base-100 shadow-sm">
                            <div class="card-body">
                                {isOpen(opp) ? (
                                    <span class="badge badge-success">Inscrições abertas</span>
                                ) : (
                                    <span class="badge badge-error">Encerrado</span>
                                )}
                                <h1 class="text-2xl md:text-3xl font-bold text-primary mt-3">{opp.name}</h1>
                                {opp.shortDescription && (
                                    <p class="text-base-content/70 mt-1">{opp.shortDescription}</p>
                                )}
                            </div>
                        </div>

                        {opp.longDescription ? (
                            <div class="card bg-base-100 shadow-sm">
                                <div class="card-body">
                                    <h2 class="text-xs font-bold uppercase tracking-wider text-base-content/50 border-b border-base-200 pb-3 mb-4">Sobre este edital</h2>
                                    <div class="prose max-w-none text-sm leading-relaxed" set:html={opp.longDescription} />
                                </div>
                            </div>
                        ) : (
                            <div class="card bg-base-100 shadow-sm">
                                <div class="card-body">
                                    <p class="text-base-content/50">Nenhuma descrição detalhada disponível.</p>
                                </div>
                            </div>
                        )}

                        <div class="flex gap-3 flex-wrap">
                            {isOpen(opp) && (
                                <a class="btn btn-primary" href={`/oportunidade/${id}/inscricoes/novo`}>Inscrever-se neste edital</a>
                            )}
                            <a class="btn btn-outline btn-primary" href={`/oportunidade/${id}/info`} target="_blank" rel="noopener">Ver no portal ↗</a>
                        </div>
                    </main>

                    <aside>
                        <div class="card bg-base-100 shadow-sm sticky top-20">
                            <div class="card-body">
                                <h2 class="text-xs font-bold uppercase tracking-wider text-base-content/50 mb-4">Informações</h2>
                                <dl class="space-y-3">
                                    {opp.type?.name && (
                                        <div>
                                            <dt class="text-xs font-bold uppercase tracking-wider text-base-content/40">Tipo</dt>
                                            <dd class="text-sm font-semibold">{opp.type.name}</dd>
                                        </div>
                                    )}
                                    <div>
                                        <dt class="text-xs font-bold uppercase tracking-wider text-base-content/40">Início das inscrições</dt>
                                        <dd class="text-sm font-semibold">{formatDate(opp.registrationFrom)}</dd>
                                    </div>
                                    <div>
                                        <dt class="text-xs font-bold uppercase tracking-wider text-base-content/40">Encerramento das inscrições</dt>
                                        <dd class={`text-sm font-semibold ${isOpen(opp) ? 'text-success' : 'text-error'}`}>{formatDate(opp.registrationTo)}</dd>
                                    </div>
                                    {opp.ownerEntity?.name && (
                                        <div>
                                            <dt class="text-xs font-bold uppercase tracking-wider text-base-content/40">Promovido por</dt>
                                            <dd class="text-sm font-semibold"><a href={`/agente/${opp.ownerEntity.id}/info`} class="text-primary hover:underline">{opp.ownerEntity.name}</a></dd>
                                        </div>
                                    )}
                                </dl>
                            </div>
                        </div>
                    </aside>

                </div>
            )}
        </div>
    </div>
</HomeLayout>
